<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Quiz Pitágoras - GitHub</title>
    <style>
        body {
            background-color: #1e3932; /* Verde Lousa */
            color: white;
            font-family: 'Arial', sans-serif;
            text-align: center;
            padding: 50px;
        }
        .quadro {
            border: 15px solid #5d4037; /* Moldura de madeira */
            padding: 40px;
            background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px);
            background-size: 20px 20px;
        }
        .botao {
            background-color: #f1f1f1;
            color: #333;
            border: none;
            padding: 15px 30px;
            margin: 10px;
            font-size: 18px;
            cursor: pointer;
            border-radius: 5px;
            transition: 0.3s;
        }
        .botao:hover { background-color: #ddd; }
    </style>
</head>
<body>

<div class="quadro">
    <h1>📐 Teorema de Pitágoras</h1>
    <h2 id="pergunta">Questão 1: Catetos medem 6 e 8. Qual a hipotenusa?</h2>
    
    <div id="alternativas">
        <button class="botao" onclick="verificar(true)">a) 10 cm</button>
        <button class="botao" onclick="verificar(false)">b) 12 cm</button>
        <button class="botao" onclick="verificar(false)">c) 14 cm</button>
        <button class="botao" onclick="verificar(false)">d) 16 cm</button>
    </div>
</div>

<script>
    function verificar(correto) {
        if(correto) {
            alert("👏 ACERTOU! (Som de Aplausos)");
            window.location.reload(); // Reinicia para simular próxima
        } else {
            alert("❌ ERROU! A resposta correta era 10 cm.");
        }
    }
</script>

</body>
</html>
